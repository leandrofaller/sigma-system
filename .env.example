# ============================================================
# SIGMA SYSTEM - Configuração de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- Banco de Dados ---
DATABASE_URL="postgresql://sigma_user:SENHA_FORTE@localhost:5432/sigma_db"
POSTGRES_PASSWORD="SENHA_FORTE_AQUI"

# --- Autenticação ---
NEXTAUTH_URL="https://seu-dominio.com"
NEXTAUTH_SECRET="gere_com_openssl_rand_base64_32"

# --- Redis (cache/sessões) ---
REDIS_URL="redis://:SENHA_REDIS@localhost:6379"
REDIS_PASSWORD="SENHA_REDIS_AQUI"

# --- OpenAI ---
OPENAI_API_KEY="sk-..."

# --- Google Gemini ---
GEMINI_API_KEY="AIza..."

# --- Google Drive (para backup) ---
GOOGLE_DRIVE_CLIENT_ID=""
GOOGLE_DRIVE_CLIENT_SECRET=""
GOOGLE_DRIVE_REFRESH_TOKEN=""
GOOGLE_DRIVE_FOLDER_ID=""

# --- Upload de arquivos ---
UPLOAD_DIR="/app/uploads"
MAX_FILE_SIZE_MB=50

# --- Sistema ---
NODE_ENV="production"
SYSTEM_NAME="SIGMA"
COVER_NAME="LogiTrack Express"
