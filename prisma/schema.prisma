  roles     String[] @default([]) // Papéis que possuem acesso (SUPER_ADMIN, ADMIN, OPERATOR)
  enabled   Boolean  @default(true) // Ativa / Inativa
  isAdmin   Boolean  @default(false) // Se pertence à seção de Administração
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sidebar_configs")
}


