generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
}

enum RelintStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  DELETION_REQUESTED
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

enum Classification {
  RESERVADO
  CONFIDENCIAL
  SECRETO
  ULTRA_SECRETO
}

enum MissionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DeviceStatus {
  PENDING
  AUTHORIZED
  REVOKED
}

enum MaintenanceStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MaintenanceSeverity {
  INFO
  WARNING
  CRITICAL
}

enum OrdemMissaoStatus {
  ATIVA
  CONCLUIDA
  VENCIDA
  CANCELADA
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  role         UserRole  @default(OPERATOR)
  groupId      String?
  group        Group?    @relation(fields: [groupId], references: [id])
  isActive     Boolean   @default(true)
  canDeletePhotos Boolean   @default(false)
  canEditApenados Boolean   @default(false)
  avatar       String?
  lastLogin    DateTime?
  lastSeenAt   DateTime?
  lastLocation Json?

  // Reconhecimento facial para login
  faceDescriptor    String?   @db.Text  // embedding 512D (JSON array) para login facial
  faceRegisteredAt  DateTime?           // data/hora do cadastro facial

  // Geolocalização
  geoStatus         String    @default("pending")  // pending|authorized|denied|admin-approved
  geoLocationData   Json?     // { lat, lng, accuracy, address, timestamp }
  geoDeniedAt       DateTime?
  geoApprovedBy     String?
  geoApprovedAt     DateTime?

  // Autenticação Multifator (2FA)
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  relints          Relint[]
  debriefings      Debriefing[]
  apenados         Apenado[]
  apenadoGroups    ApenadoGroup[]
  sentMessages     ChatMessage[]   @relation("SentMessages")
  receivedMessages ChatMessage[]   @relation("ReceivedMessages")
  auditLogs        AuditLog[]
  aiQueries        AIQuery[]
  uploadedFiles    ReceivedRelint[]
  arquivoFiles     ArquivoFile[]
  locations        UserLocation[]
  missions         Mission[]
  boardCardsCreated BoardCard[]         @relation("CreatedCards")
  boardCardAssignments BoardCardAssignee[]
  boardComments    BoardComment[]
  devices          UserDevice[]
  aipApenadoAnexos AIPApenadoAnexo[]
  maintenanceAvisos SystemMaintenance[]
  relatoriosForcaTarefa RelatorioForcaTarefa[]

  // Mural de Eventos
  eventsCreated OccurrenceEvent[] @relation("EventsCreatedBy")
  eventsUpdated OccurrenceEvent[] @relation("EventsUpdatedBy")
  eventsDeleted OccurrenceEvent[] @relation("EventsDeletedBy")
  attachmentsUploaded EventAttachment[]
  deletionRequestsCreated DeleteApprovalRequest[] @relation("DeletionRequestedBy")
  deletionRequestsResponded DeleteApprovalRequest[] @relation("DeletionRespondedBy")

  ordensEmitidas      OrdemMissao[]             @relation("OrdensMissaoEmitidas")
  ordensParticipacoes OrdemMissaoParticipante[] @relation("OrdensMissaoParticipacoes")
  ordensConcluidas    OrdemMissao[]             @relation("OrdensMissaoConcluidas")
  pichacoesCadastradas PichacaoFacciosa[]        @relation("PichacoesCadastradas")
  aparelhosCriados     AparelhoApreendido[]      @relation("AparelhosCriados")

  unidadeEnderecoOverridesAtualizados UnidadeEnderecoOverride[] @relation("UnidadeOverrideAtualizado")
  unidadeEnderecoSolicitacoesEnviadas UnidadeEnderecoSolicitacao[] @relation("UnidadeSolicitacaoEnviada")
  unidadeEnderecoSolicitacoesRevisadas UnidadeEnderecoSolicitacao[] @relation("UnidadeSolicitacaoRevisada")
  unidadeEnderecoCustomCriadas         UnidadeEnderecoCustom[] @relation("UnidadeCustomCriada")
  unidadeEnderecoCustomRevisadas       UnidadeEnderecoCustom[] @relation("UnidadeCustomRevisada")

  @@map("users")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String?  @default("#6172f3")
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  relints         Relint[]
  debriefings     Debriefing[]
  messages        ChatMessage[]
  receivedRelints ReceivedRelint[]
  missions        Mission[]
  relatoriosForcaTarefa RelatorioForcaTarefa[]
  arquivoFiles    ArquivoFile[]
  arquivoFolders  ArquivoFolder[]

  @@map("groups")
}

model Relint {
  id             String         @id @default(cuid())
  number         String         @unique
  date           DateTime
  subject        String
  diffusion      String
  content        Json
  status         RelintStatus   @default(DRAFT)
  classification Classification @default(RESERVADO)
  authorId       String
  author         User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  groupId        String
  group          Group          @relation(fields: [groupId], references: [id])
  templateId     String?
  template       RelintTemplate? @relation(fields: [templateId], references: [id])
  driveFileId    String?
  pdfPath        String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  attachments Attachment[]

  @@index([groupId])
  @@index([authorId])
  @@index([status])
  @@map("relints")
}

model RelintTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  fields      Json
  layout      Json
  headerHtml  String?  @db.Text
  footerHtml  String?  @db.Text
  logoUrl     String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  relints Relint[]

  @@map("relint_templates")
}

model ReceivedRelintFolder {
  id        String   @id @default(cuid())
  name      String
  color     String?  @default("#6172f3")
  createdAt DateTime @default(now())

  files ReceivedRelint[]

  @@map("received_relint_folders")
}

model ReceivedRelint {
  id             String         @id @default(cuid())
  title          String
  filename       String
  originalName   String
  source         String
  fileType       String
  fileSize       Int
  driveFileId    String?
  localPath      String?
  classification Classification @default(RESERVADO)
  uploadedById   String
  uploadedBy     User           @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  groupId        String?
  group          Group?         @relation(fields: [groupId], references: [id])
  folderId       String?
  folder         ReceivedRelintFolder? @relation(fields: [folderId], references: [id])
  notes          String?        @db.Text
  tags           String[]
  createdAt      DateTime       @default(now())

  @@index([groupId])
  @@index([folderId])
  @@map("received_relints")
}

model ChatMessage {
  id         String      @id @default(cuid())
  content    String      @db.Text
  type       MessageType @default(TEXT)
  fileUrl    String?
  fileName   String?
  fileSize   Int?
  senderId   String
  sender     User        @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String?
  receiver   User?       @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  groupId    String?
  group      Group?      @relation(fields: [groupId], references: [id])
  readBy     String[]    @default([])
  reactions  Json?
  isDeleted  Boolean     @default(false)
  createdAt  DateTime    @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([groupId])
  @@index([createdAt])
  @@map("chat_messages")
}

model Attachment {
  id           String   @id @default(cuid())
  relintId     String
  relint       Relint   @relation(fields: [relintId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  fileType     String
  fileSize     Int
  driveFileId  String?
  localPath    String?
  createdAt    DateTime @default(now())

  @@map("attachments")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  // Integridade encadeada (Logs invioláveis)
  hash       String?
  parentHash String?

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}

model AIQuery {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String   @db.Text
  response  String   @db.Text
  provider  String
  model     String?
  tokens    Int?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("ai_queries")
}

model AccessRequest {
  id         String    @id @default(cuid())
  name       String
  email      String
  message    String?   @db.Text
  status     String    @default("PENDING")
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([status])
  @@map("access_requests")
}

model UserLocation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  accuracy  Float?
  address   String?
  timestamp DateTime @default(now())

  @@index([userId, timestamp])
  @@map("user_locations")
}

model Debriefing {
  id            String         @id @default(cuid())
  number        String         @unique
  date          DateTime
  missionDate    DateTime?
  missionEndDate DateTime?
  missionCode   String?
  operationType String?
  operatives    String?
  handler       String?
  location      String?
  subject       String
  diffusion     String
  content       Json
  status        RelintStatus   @default(DRAFT)
  classification Classification @default(RESERVADO)
  authorId      String
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  groupId       String
  group         Group          @relation(fields: [groupId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([groupId])
  @@index([authorId])
  @@index([status])
  @@map("debriefings")
}

model Mission {
  id          String        @id @default(cuid())
  title       String
  description String?       @db.Text
  destination String
  startDate   DateTime      // Data AGENDADA (planejada)
  endDate     DateTime?     // Previsão de fim (opcional, definida no agendamento)
  startedAt   DateTime?     // Hora REAL de início (preenchida quando o usuário inicia)
  endedAt     DateTime?     // Hora REAL de finalização
  endNote     String?       @db.Text  // Observação opcional na finalização (ex: interrompida por X)
  status      MissionStatus @default(PLANNED)
  participants String[]      @default([])
  placa       String?
  startKm     Float?
  endKm       Float?
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId     String?
  group       Group?         @relation(fields: [groupId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  boardLists  BoardList[]

  @@index([userId])
  @@index([groupId])
  @@index([status])
  @@map("missions")
}

model BoardList {
  id        String   @id @default(cuid())
  missionId String
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  name      String
  position  Float    @default(0)
  color     String?  @default("#6172f3")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cards BoardCard[]

  @@index([missionId])
  @@map("board_lists")
}

model BoardCard {
  id          String   @id @default(cuid())
  listId      String
  list        BoardList @relation(fields: [listId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  position    Float    @default(0)
  dueDate     DateTime?
  createdById String
  createdBy   User     @relation("CreatedCards", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignees   BoardCardAssignee[]
  checklist   BoardChecklistItem[]
  comments    BoardComment[]

  @@index([listId])
  @@map("board_cards")
}

model BoardCardAssignee {
  cardId    String
  userId    String
  card      BoardCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@id([cardId, userId])
  @@index([userId])
  @@map("board_card_assignees")
}

model BoardChecklistItem {
  id        String   @id @default(cuid())
  cardId    String
  card      BoardCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  text      String
  done      Boolean  @default(false)
  position  Float    @default(0)
  createdAt DateTime @default(now())

  @@index([cardId])
  @@map("board_checklist_items")
}

model Apenado {
  id          String   @id @default(cuid())
  name        String
  matricula   String?
  unidade     String?
  photoPath      String?
  photoHash      String?
  photoHashSha   String?  @db.VarChar(64)
  photoQuality   Float?
  faccao         String?
  notes          String?  @db.Text
  faceDescriptor String?  @db.Text
  detScore       Float?
  faceDescriptorAdvanced String?  @db.Text
  advancedDetScore       Float?
  advancedQualityScore   Float?
  advancedLivenessScore  Float?
  ocrText        String?  @db.Text
  ocrName        String?
  photoCategory      String?   // FACE_OK | FACE_MISSED | DOCUMENT | TATTOO | BODY | NO_FACE
  photoCategoryConf  Float?
  photoCategoryReason String?  @db.Text
  photoClassifiedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  groups           ApenadoGroupMember[]
  sipeImportacoes  SipeApenadoImportado[]
  fotosComplementares SipeFotoComplementar[]
  sanitizations    ImageSanitization[]

  @@index([name])
  @@index([matricula])
  @@index([unidade])
  @@index([photoHash])
  @@index([photoHashSha])
  @@index([photoQuality])
  @@index([detScore])
  @@index([photoCategory])
  @@index([photoClassifiedAt])
  @@map("apenados")
}

model ImageSanitization {
  id              String   @id @default(cuid())
  apenadoId       String?  // ID do apenado local correspondente (opcional)
  photoPath       String   // Caminho físico atual (ex: uploads/quarentena/sem_rosto/...)
  originalPath    String   // Caminho original da imagem (ex: uploads/apenados/...)
  status          String   // "CLEAN" | "NO_FACE" | "LOW_QUALITY" | "DUPLICATE" | "APPROVED" | "REJECTED"
  reason          String?  // Motivo da classificação
  score           Float?   // Score de detecção facial ou de qualidade
  hashPerceptual  String?  // pHash da imagem
  duplicateOfId   String?  // ID do apenado do qual é duplicada
  analyzedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  apenado         Apenado? @relation(fields: [apenadoId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([apenadoId])
  @@map("image_sanitizations")
}

model UserDevice {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String       @unique
  name         String
  userAgent    String
  ipAddress    String
  status       DeviceStatus @default(PENDING)
  authorizedBy    String?
  authorizedAt    DateTime?
  lastUsedAt      DateTime     @default(now())
  createdAt       DateTime     @default(now())
  latitude        Float?
  longitude       Float?
  locationAddress String?
  locationAt      DateTime?

  // Geolocalização
  geoLocationData   Json?     // { lat, lng, accuracy, address, timestamp }
  geoPermissionDenied Boolean @default(false)
  geoForcedApproval Boolean   @default(false)

  @@index([userId, status])
  @@map("user_devices")
}

model BoardComment {
  id        String   @id @default(cuid())
  cardId    String
  card      BoardCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([cardId, createdAt])
  @@map("board_comments")
}

model ApenadoGroup {
  id            String   @id @default(cuid())
  name          String
  description   String?
  baseApenadoId String?
  createdAt     DateTime @default(now())
  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  members ApenadoGroupMember[]

  @@map("apenado_groups")
}

model ApenadoGroupMember {
  groupId    String
  apenadoId  String
  similarity Float?
  addedAt    DateTime @default(now())

  group   ApenadoGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  apenado Apenado      @relation(fields: [apenadoId], references: [id], onDelete: Cascade)

  @@id([groupId, apenadoId])
  @@map("apenado_group_members")
}

// ── SIPE Integration ──────────────────────────────────────────

model SipeFaccao {
  id        String   @id @default(cuid())
  sipeId    Int      @unique
  nome      String
  sigla     String?
  cor       String?  @default("#ef4444")
  descricao String?  @db.Text
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apenados SipeApenadoImportado[]
  apenadosUnidades SipeApenadoUnidadePrisional[]
  pichacoes        PichacaoFacciosa[]          @relation("FaccoesPichacoes")

  @@map("sipe_faccoes")
}

model SipeApenadoImportado {
  id             String  @id @default(cuid())
  sipeId         Int     @unique
  apenadoLocalId String?
  apenado        Apenado? @relation(fields: [apenadoLocalId], references: [id], onDelete: SetNull)
  photoPath      String?

  nome             String
  nomeOutro        String?
  cpf              String?
  rg               String?
  rgOrgao          String?
  dataNascimento   String?
  naturalidade     String?
  nacionalidade    String?
  pais             String?
  sexo             String?
  etnia            String?
  orientacaoSexual String?
  tipoSanguineo    String?
  grauInstrucao    String?
  religiao         String?
  estadoCivil      String?
  nomeConjuge      String?
  qtdFilhos        Int?
  nomeMae          String?
  nomePai          String?
  telefone         String?
  rji              String?

  unidade      String?
  cela         String?
  regime       String?
  motivoUltimaMovimentacao String?
  situacao     String?
  dataEntrada  String?
  dataPrisao   String?
  tempoPena    String?
  monitorado   Boolean?
  intramuro    Boolean?
  presoOriundo String?
  oficioEntrada String?

  faccaoId  String?
  faccao    SipeFaccao? @relation(fields: [faccaoId], references: [id], onDelete: SetNull)

  // Endereço residencial
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  uf           String?
  cep          String?

  // Histórico
  celeAtual            String?
  ultimaMovimentacao   DateTime?

  ultimaSyncAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  processos        SipeProcesso[]
  alcunhas         SipeAlcunha[]
  vinculosAdvogado SipeVinculoAdvogado[]
  vinculosVisitante SipeVinculoVisitante[]
  historicos       SipeHistorico[]
  documentos       SipeDocumento[]
  fotosComplementares SipeFotoComplementar[]
  aipApenado       AIPApenado?  @relation("AIPApenadoToSipeApenado")

  @@index([nome])
  @@index([cpf])
  @@index([faccaoId])
  @@index([apenadoLocalId])
  @@map("sipe_apenados_importados")
}

model SipeAlcunha {
  id        String               @id @default(cuid())
  apenadoId String
  apenado   SipeApenadoImportado @relation(fields: [apenadoId], references: [id], onDelete: Cascade)
  alcunha   String
  createdAt DateTime             @default(now())

  @@index([apenadoId])
  @@map("sipe_alcunhas")
}

model SipeProcesso {
  id             String               @id @default(cuid())
  apenadoId      String
  apenado        SipeApenadoImportado @relation(fields: [apenadoId], references: [id], onDelete: Cascade)
  sipeProcessoId Int?
  numero         String?
  vara           String?
  artigos        String[]
  tempoPena      String?
  principal      Boolean              @default(false)
  createdAt      DateTime             @default(now())

  @@index([apenadoId])
  @@map("sipe_processos")
}

model SipeAdvogado {
  id           String   @id @default(cuid())
  sipeId       Int      @unique
  nome         String
  oab          String?
  cpf          String?
  endereco     String?
  telefone     String?
  dataCadastro String?
  photoPath    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vinculos SipeVinculoAdvogado[]

  @@index([nome])
  @@index([oab])
  @@map("sipe_advogados")
}

model SipeVisitante {
  id                 String   @id @default(cuid())
  nome               String
  cpf                String?
  parentesco         String?
  photoPath          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Novos campos pessoais da ficha geral
  carteirinha        String?
  certidaoNascimento String?
  dataNascimento     String?
  sexo               String?
  telefone           String?
  naturalidade       String?
  dataCarteirinha    String?
  nomeMae            String?
  nomePai            String?
  logradouro         String?
  numero             String?
  bairro             String?
  cidadeUf           String?

  // Campos de indexação e biometria facial ArcFace
  photoHash          String?
  photoHashSha       String?  @db.VarChar(64)
  faceDescriptor     String?  @db.Text
  detScore           Float?
  photoQuality       Float?

  vinculos SipeVinculoVisitante[]
  entradas SipeVisitanteEntrada[]

  @@index([nome])
  @@index([cpf])
  @@map("sipe_visitantes")
}

model SipeVisitanteEntrada {
  id               String        @id @default(cuid())
  visitanteId      String
  visitante        SipeVisitante @relation(fields: [visitanteId], references: [id], onDelete: Cascade)
  tipo             String?
  nomeApenado      String?
  unidadePrisional String?
  dataEntrada      DateTime?
  dia              String?
  situacao         String?
  createdAt        DateTime      @default(now())

  @@index([visitanteId])
  @@map("sipe_visitante_entradas")
}

model SipeVinculoAdvogado {
  id         String               @id @default(cuid())
  apenadoId  String
  apenado    SipeApenadoImportado @relation(fields: [apenadoId], references: [id], onDelete: Cascade)
  advogadoId String
  advogado   SipeAdvogado         @relation(fields: [advogadoId], references: [id], onDelete: Cascade)
  ativo      Boolean              @default(true)
  createdAt  DateTime             @default(now())

  @@unique([apenadoId, advogadoId])
  @@index([apenadoId])
  @@index([advogadoId])
  @@map("sipe_vinculos_advogados")
}

model SipeVinculoVisitante {
  id          String               @id @default(cuid())
  apenadoId   String
