  solicitadoPorId   String
  solicitadoPor     User                             @relation("UnidadeSolicitacaoEnviada", fields: [solicitadoPorId], references: [id], onDelete: Cascade)
  solicitadoEm      DateTime                         @default(now())
  revisadoPorId     String?
  revisadoPor       User?                            @relation("UnidadeSolicitacaoRevisada", fields: [revisadoPorId], references: [id], onDelete: SetNull)
  revisadoEm        DateTime?
  motivoRejeicao    String?                          @db.Text

  @@index([status])
  @@index([unidadeId])
  @@index([solicitadoEm])
  @@map("unidade_endereco_solicitacoes")
}

enum UnidadeEnderecoCustomStatus {
  PENDENTE
  ATIVA
  REJEITADA
}

// Unidades prisionais criadas pelos usuários (fora do catálogo estático).
model UnidadeEnderecoCustom {
  id              String                        @id
  comarca         String
  unidade         String
  endereco        String
  cep             String                        @default("")
  latitude        Float?
  longitude       Float?
  status          UnidadeEnderecoCustomStatus   @default(PENDENTE)
  criadoPorId     String
  criadoPor       User                          @relation("UnidadeCustomCriada", fields: [criadoPorId], references: [id], onDelete: Cascade)
  revisadoPorId   String?
  revisadoPor     User?                         @relation("UnidadeCustomRevisada", fields: [revisadoPorId], references: [id], onDelete: SetNull)
  revisadoEm      DateTime?
  motivoRejeicao  String?                       @db.Text
  criadoEm        DateTime                      @default(now())
  atualizadoEm    DateTime                      @updatedAt

  @@index([status])
  @@index([comarca])
  @@map("unidade_endereco_custom")
}

model Geofence {
  id          String   @id @default(cuid())
  name        String
  type        String   // "circle" | "polygon"
  action      String   // "allow" | "deny"
  coordinates Json     // Circular: { lat: float, lng: float, radius: float }
                       // Polígono: [{ lat: float, lng: float }, ...]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("geofences")
}

model PichacaoFacciosa {
  id              String      @id @default(cuid())
  municipio       String      // Município de RO onde foi localizada
  endereco        String      // Endereço ou ponto de referência
  latitude        Float?
  longitude       Float?
  faccaoId        String?
  faccao          SipeFaccao? @relation("FaccoesPichacoes", fields: [faccaoId], references: [id], onDelete: SetNull)
  descricao       String?     @db.Text // Detalhes da pichação ou símbolos
  fotos           String[]    // URLs/caminhos das imagens carregadas
  cadastradoPorId String
  cadastradoPor   User        @relation("PichacoesCadastradas", fields: [cadastradoPorId], references: [id])
  dataRegistro    DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([municipio])
  @@index([faccaoId])
  @@index([cadastradoPorId])
  @@map("pichacoes_faccionados")
}

// ─── Arquivo ──────────────────────────────────────────────────────────────────

model ArquivoFolder {
  id        String        @id @default(cuid())
  name      String
  color     String?       @default("#6172f3")
  groupId   String?
  group     Group?        @relation(fields: [groupId], references: [id])
  createdAt DateTime      @default(now())

  files ArquivoFile[]

  @@map("arquivo_folders")
}

model ArquivoFile {
  id             String          @id @default(cuid())
  title          String
  filename       String
  originalName   String
  source         String?
  fileType       String
  fileSize       Int
  localPath      String?
  classification Classification
  uploadedById   String
  uploadedBy     User            @relation(fields: [uploadedById], references: [id])
  groupId        String?
  group          Group?          @relation(fields: [groupId], references: [id])
  folderId       String?
  folder         ArquivoFolder?  @relation(fields: [folderId], references: [id])
  notes          String?
  tags           String[]
  createdAt      DateTime        @default(now())

  @@index([groupId])
  @@index([folderId])
  @@map("arquivo_files")
}
