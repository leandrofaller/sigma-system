// ============================================================
// AIP (Análise de Inteligência Penitenciária)
// Sistema dual de dados: SIPE (sincronizável) + Inteligência (permanente)
// ============================================================

model AIPApenado {
  id String @id @default(cuid())

  // ============ VÍNCULO COM SIPE ============
  // Permite atualizar dados SIPE de novo scraping
  // Nullable com SetNull: deletar o registro SIPE não apaga o AIP — apenas desvincula
  sipeApenadoId Int?  @unique
  sipeApenado   SipeApenadoImportado? @relation("AIPApenadoToSipeApenado", fields: [sipeApenadoId], references: [sipeId], onDelete: SetNull)

  // ============ DADOS DO SIPE (atualizáveis) ============
  // Copiados inicialmente de SipeApenadoImportado
  // Atualizados automaticamente quando novo scraping acontece

  // Dados Pessoais
  nome              String
  nomeOutro         String?
  cpf               String?
  rg                String?
  rgOrgao           String?
  dataNascimento    String? // YYYY-MM-DD
  sexo              String? // M/F
  etnia             String?
  naturalidade      String?
  nacionalidade     String?
  pais              String?
  orientacaoSexual  String?
  tipoSanguineo     String?
  grauInstrucao     String?
  religiao          String?
  estadoCivil       String?
  nomeConjuge       String?
  qtdFilhos         Int?
  nomeMae           String?
  nomePai           String?
  telefone          String?
  rji               String?

  // Dados Prisionais
  unidade           String?
  cela              String?
  regime            String?
  motivoUltimaMovimentacao String?
  situacao          String?
  dataEntrada       String?
  dataPrisao        String?
  tempoPena         String?
  faccao            String? // nome da facção conforme SIPE
  monitorado        Boolean?
  intramuro         Boolean?
  presoOriundo      String?
  oficioEntrada     String?
  celeAtual         String?
  ultimaMovimentacao DateTime?

  // Endereço Residencial
  logradouro        String?
  numero            String?
  complemento       String?
  bairro            String?
  cidade            String?
  uf                String?
  cep               String?

  // Fotos (caminho local do arquivo salvo)
  photoPath         String? // foto de identificação do apenado

  // Identificadores SIPE
  sipeId            Int     @unique

  // ============ DADOS DE INTELIGÊNCIA (imutáveis pelo Limpar Tudo) ============
  // Adicionados manualmente pelo analista, nunca sobrescritos

  // Override de facção (inteligência corrige SIPE)
  facaoRealNome        String?
  facaoNivel           String? // "confirmado", "suspeita", "negado"
  facaoDataVerificacao DateTime?
  facaoRelevancia      String? // "Membro", "Membro de Relevancia", "Liderança", "Já exerceu Liderança"
  vulgo                String?
  custodiaReal         String?

  // Campos de inteligência gerais
  notasInteligencia String? @db.Text
  observacoes       String? @db.Text

  // Metadata de inteligência
  cadastradoEm  DateTime  @default(now())
  cadastradoPor String
  atualizadoEm  DateTime  @updatedAt
  atualizadoPor String?
  ultimaSincAt  DateTime? // quando foi sincronizado pela última vez

  // Status
  ativo Boolean @default(true)

  // Relacionamentos
  vinculos AIPVinculo[]
  fotoVisitantes AIPFotoVisitante[]
  anexos AIPApenadoAnexo[]
  mapaVinculos MapaFaccaoVinculo[]

  @@index([sipeId])
  @@index([unidade])
  @@index([facaoRealNome])
  @@index([cadastradoEm])
  @@map("aip_apenados")
}

model AIPApenadoAnexo {
  id              String    @id @default(cuid())
  apenadoId       String
  apenado         AIPApenado @relation(fields: [apenadoId], references: [id], onDelete: Cascade)

  // Informações do arquivo
  nomeOriginal    String    // Nome original do arquivo
  nomeS3          String    // Nome armazenado em S3 (com hash)
  tipoMime        String    // application/pdf, image/jpeg, etc
  tamanhoOriginal Int       // Tamanho antes da compactação
  tamanhoS3       Int       // Tamanho após compactação

  // Localização
  urlS3           String    // https://bucket.s3.amazonaws.com/...
  chaveS3         String    // aip-anexos/apenado-id/hash-timestamp.pdf

  // Metadados
  usuarioUploadId String
  usuarioUpload   User      @relation(fields: [usuarioUploadId], references: [id])
  dataUpload      DateTime  @default(now())
  descricao       String?   @db.Text

