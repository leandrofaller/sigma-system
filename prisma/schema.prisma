generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
}

enum RelintStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  DELETION_REQUESTED
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

enum Classification {
  RESERVADO
  CONFIDENCIAL
  SECRETO
  ULTRA_SECRETO
}

enum MissionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DeviceStatus {
  PENDING
  AUTHORIZED
  REVOKED
}

enum MaintenanceStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MaintenanceSeverity {
  INFO
  WARNING
  CRITICAL
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  role         UserRole  @default(OPERATOR)
  groupId      String?
  group        Group?    @relation(fields: [groupId], references: [id])
  isActive     Boolean   @default(true)
  avatar       String?
  lastLogin    DateTime?
  lastSeenAt   DateTime?
  lastLocation Json?

  // Reconhecimento facial para login
  faceDescriptor    String?   @db.Text  // embedding 512D (JSON array) para login facial
  faceRegisteredAt  DateTime?           // data/hora do cadastro facial

  // Geolocalização
  geoStatus         String    @default("pending")  // pending|authorized|denied|admin-approved
  geoLocationData   Json?     // { lat, lng, accuracy, address, timestamp }
  geoDeniedAt       DateTime?
  geoApprovedBy     String?
  geoApprovedAt     DateTime?

  // Autenticação Multifator (2FA)
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  relints          Relint[]
  debriefings      Debriefing[]
  apenados         Apenado[]
  apenadoGroups    ApenadoGroup[]
  sentMessages     ChatMessage[]   @relation("SentMessages")
  receivedMessages ChatMessage[]   @relation("ReceivedMessages")
  auditLogs        AuditLog[]
  aiQueries        AIQuery[]
  uploadedFiles    ReceivedRelint[]
  locations        UserLocation[]
  missions         Mission[]
  boardCardsCreated BoardCard[]         @relation("CreatedCards")
  boardCardAssignments BoardCardAssignee[]
  boardComments    BoardComment[]
  devices          UserDevice[]
  aipApenadoAnexos AIPApenadoAnexo[]
  maintenanceAvisos SystemMaintenance[]
  relatoriosForcaTarefa RelatorioForcaTarefa[]

  // Mural de Eventos
  eventsCreated OccurrenceEvent[] @relation("EventsCreatedBy")
  eventsUpdated OccurrenceEvent[] @relation("EventsUpdatedBy")
  eventsDeleted OccurrenceEvent[] @relation("EventsDeletedBy")
  attachmentsUploaded EventAttachment[]
  deletionRequestsCreated DeleteApprovalRequest[] @relation("DeletionRequestedBy")
  deletionRequestsResponded DeleteApprovalRequest[] @relation("DeletionRespondedBy")

  @@map("users")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String?  @default("#6172f3")
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  relints         Relint[]
  debriefings     Debriefing[]
  messages        ChatMessage[]
  receivedRelints ReceivedRelint[]
  missions        Mission[]
  relatoriosForcaTarefa RelatorioForcaTarefa[]

  @@map("groups")
}

model Relint {
  id             String         @id @default(cuid())
  number         String         @unique
  date           DateTime
  subject        String
  diffusion      String
  content        Json
  status         RelintStatus   @default(DRAFT)
  classification Classification @default(RESERVADO)
  authorId       String
  author         User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  groupId        String
  group          Group          @relation(fields: [groupId], references: [id])
  templateId     String?
  template       RelintTemplate? @relation(fields: [templateId], references: [id])
  driveFileId    String?
  pdfPath        String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  attachments Attachment[]

  @@index([groupId])
  @@index([authorId])
  @@index([status])
  @@map("relints")
}

model RelintTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  fields      Json
  layout      Json
  headerHtml  String?  @db.Text
  footerHtml  String?  @db.Text
  logoUrl     String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  relints Relint[]

  @@map("relint_templates")
}

model ReceivedRelintFolder {
  id        String   @id @default(cuid())
  name      String
  color     String?  @default("#6172f3")
  createdAt DateTime @default(now())

  files ReceivedRelint[]

  @@map("received_relint_folders")
}

model ReceivedRelint {
  id             String         @id @default(cuid())
  title          String
  filename       String
  originalName   String
  source         String
  fileType       String
  fileSize       Int
  driveFileId    String?
  localPath      String?
  classification Classification @default(RESERVADO)
  uploadedById   String
  uploadedBy     User           @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  groupId        String?
  group          Group?         @relation(fields: [groupId], references: [id])
  folderId       String?
  folder         ReceivedRelintFolder? @relation(fields: [folderId], references: [id])
  notes          String?        @db.Text
  tags           String[]
  createdAt      DateTime       @default(now())

  @@index([groupId])
  @@index([folderId])
  @@map("received_relints")
}

model ChatMessage {
  id         String      @id @default(cuid())
  content    String      @db.Text
  type       MessageType @default(TEXT)
  fileUrl    String?
  fileName   String?
  fileSize   Int?
  senderId   String
  sender     User        @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String?
  receiver   User?       @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  groupId    String?
  group      Group?      @relation(fields: [groupId], references: [id])
  readBy     String[]    @default([])
  reactions  Json?
  isDeleted  Boolean     @default(false)
  createdAt  DateTime    @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([groupId])
  @@index([createdAt])
  @@map("chat_messages")
}

model Attachment {
  id           String   @id @default(cuid())
  relintId     String
  relint       Relint   @relation(fields: [relintId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  fileType     String
  fileSize     Int
  driveFileId  String?
  localPath    String?
  createdAt    DateTime @default(now())

  @@map("attachments")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  // Integridade encadeada (Logs invioláveis)
  hash       String?
  parentHash String?

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedBy   String?
  updatedAt   DateTime @updatedAt

  @@map("system_configs")
}

model AIQuery {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String   @db.Text
  response  String   @db.Text
  provider  String
  model     String?
  tokens    Int?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("ai_queries")
}

model AccessRequest {
  id         String    @id @default(cuid())
  name       String
  email      String
  message    String?   @db.Text
  status     String    @default("PENDING")
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([status])
  @@map("access_requests")
}

model UserLocation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  accuracy  Float?
  address   String?
  timestamp DateTime @default(now())

  @@index([userId, timestamp])
  @@map("user_locations")
}

model Debriefing {
  id            String         @id @default(cuid())
  number        String         @unique
  date          DateTime
  missionDate    DateTime?
  missionEndDate DateTime?
  missionCode   String?
  operationType String?
  operatives    String?
  handler       String?
  location      String?
  subject       String
  diffusion     String
  content       Json
  status        RelintStatus   @default(DRAFT)
  classification Classification @default(RESERVADO)
  authorId      String
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  groupId       String
  group         Group          @relation(fields: [groupId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([groupId])
  @@index([authorId])
  @@index([status])
  @@map("debriefings")
}

model Mission {
  id          String        @id @default(cuid())
  title       String
  description String?       @db.Text
  destination String
  startDate   DateTime      // Data AGENDADA (planejada)
  endDate     DateTime?     // Previsão de fim (opcional, definida no agendamento)
  startedAt   DateTime?     // Hora REAL de início (preenchida quando o usuário inicia)
  endedAt     DateTime?     // Hora REAL de finalização
  endNote     String?       @db.Text  // Observação opcional na finalização (ex: interrompida por X)
  status      MissionStatus @default(PLANNED)
  participants String[]      @default([])
  placa       String?
  startKm     Float?
  endKm       Float?
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId     String?
  group       Group?         @relation(fields: [groupId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  boardLists  BoardList[]

  @@index([userId])
  @@index([groupId])
  @@index([status])
  @@map("missions")
}

model BoardList {
  id        String   @id @default(cuid())
  missionId String
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  name      String
  position  Float    @default(0)
  color     String?  @default("#6172f3")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cards BoardCard[]

  @@index([missionId])
  @@map("board_lists")
}

model BoardCard {
  id          String   @id @default(cuid())
  listId      String
  list        BoardList @relation(fields: [listId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  position    Float    @default(0)
  dueDate     DateTime?
  createdById String
  createdBy   User     @relation("CreatedCards", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignees   BoardCardAssignee[]
  checklist   BoardChecklistItem[]
  comments    BoardComment[]

  @@index([listId])
  @@map("board_cards")
}

model BoardCardAssignee {
  cardId    String
  userId    String
  card      BoardCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@id([cardId, userId])
  @@index([userId])
  @@map("board_card_assignees")
}

model BoardChecklistItem {
  id        String   @id @default(cuid())
  cardId    String
  card      BoardCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  text      String
  done      Boolean  @default(false)
  position  Float    @default(0)
  createdAt DateTime @default(now())

  @@index([cardId])
  @@map("board_checklist_items")
}

model Apenado {
  id          String   @id @default(cuid())
  name        String
  matricula   String?
  unidade     String?
  photoPath      String?
  photoHash      String?
  photoHashSha   String?  @db.VarChar(64)
  photoQuality   Float?
  faccao         String?
  notes          String?  @db.Text
  faceDescriptor String?  @db.Text
  detScore       Float?
  faceDescriptorAdvanced String?  @db.Text
  advancedDetScore       Float?
  advancedQualityScore   Float?
  advancedLivenessScore  Float?
  ocrText        String?  @db.Text
  ocrName        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  groups           ApenadoGroupMember[]
  sipeImportacoes  SipeApenadoImportado[]
  fotosComplementares SipeFotoComplementar[]

  @@index([name])
  @@index([matricula])
  @@index([unidade])
  @@index([photoHash])
  @@index([photoHashSha])
  @@index([photoQuality])
  @@index([detScore])
  @@map("apenados")
}

model UserDevice {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String       @unique
  name         String
  userAgent    String
  ipAddress    String
  status       DeviceStatus @default(PENDING)
  authorizedBy    String?
  authorizedAt    DateTime?
  lastUsedAt      DateTime     @default(now())
  createdAt       DateTime     @default(now())
  latitude        Float?
  longitude       Float?
  locationAddress String?
  locationAt      DateTime?

  // Geolocalização
  geoLocationData   Json?     // { lat, lng, accuracy, address, timestamp }
  geoPermissionDenied Boolean @default(false)
  geoForcedApproval Boolean   @default(false)

  @@index([userId, status])
  @@map("user_devices")
}

model BoardComment {
  id        String   @id @default(cuid())
  cardId    String
  card      BoardCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([cardId, createdAt])
  @@map("board_comments")
}

model ApenadoGroup {
  id            String   @id @default(cuid())
  name          String
  description   String?
  baseApenadoId String?
  createdAt     DateTime @default(now())
  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  members ApenadoGroupMember[]

  @@map("apenado_groups")
}

model ApenadoGroupMember {
  groupId    String
  apenadoId  String
  similarity Float?
  addedAt    DateTime @default(now())

  group   ApenadoGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  apenado Apenado      @relation(fields: [apenadoId], references: [id], onDelete: Cascade)

  @@id([groupId, apenadoId])
  @@map("apenado_group_members")
}

// ── SIPE Integration ──────────────────────────────────────────

model SipeFaccao {
  id        String   @id @default(cuid())
  sipeId    Int      @unique
  nome      String
  sigla     String?
  cor       String?  @default("#ef4444")
  descricao String?  @db.Text
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apenados SipeApenadoImportado[]
  apenadosUnidades SipeApenadoUnidadePrisional[]

  @@map("sipe_faccoes")
}

model SipeApenadoImportado {
  id             String  @id @default(cuid())
  sipeId         Int     @unique
  apenadoLocalId String?
  apenado        Apenado? @relation(fields: [apenadoLocalId], references: [id], onDelete: SetNull)
  photoPath      String?

  nome             String
  nomeOutro        String?
  cpf              String?
  rg               String?
  rgOrgao          String?
  dataNascimento   String?
  naturalidade     String?
  nacionalidade    String?
  pais             String?
  sexo             String?
  etnia            String?
  orientacaoSexual String?
  tipoSanguineo    String?
  grauInstrucao    String?
  religiao         String?
  estadoCivil      String?
  nomeConjuge      String?
  qtdFilhos        Int?
  nomeMae          String?
  nomePai          String?
  telefone         String?
  rji              String?

  unidade      String?
  cela         String?
  regime       String?
  motivoUltimaMovimentacao String?
  situacao     String?
  dataEntrada  String?
  dataPrisao   String?
  tempoPena    String?
  monitorado   Boolean?
  intramuro    Boolean?
  presoOriundo String?
  oficioEntrada String?

  faccaoId  String?
  faccao    SipeFaccao? @relation(fields: [faccaoId], references: [id], onDelete: SetNull)

  // Endereço residencial
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  uf           String?
  cep          String?

  // Histórico
  celeAtual            String?
  ultimaMovimentacao   DateTime?

  ultimaSyncAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  processos        SipeProcesso[]
  alcunhas         SipeAlcunha[]
  vinculosAdvogado SipeVinculoAdvogado[]
  vinculosVisitante SipeVinculoVisitante[]
  historicos       SipeHistorico[]
  documentos       SipeDocumento[]
  fotosComplementares SipeFotoComplementar[]
  aipApenado       AIPApenado?  @relation("AIPApenadoToSipeApenado")

  @@index([nome])
  @@index([cpf])
  @@index([faccaoId])
  @@map("sipe_apenados_importados")
}

model SipeAlcunha {
  id        String               @id @default(cuid())
  apenadoId String
  apenado   SipeApenadoImportado @relation(fields: [apenadoId], references: [id], onDelete: Cascade)
  alcunha   String
  createdAt DateTime             @default(now())

  @@index([apenadoId])
  @@map("sipe_alcunhas")
}

model SipeProcesso {
  id             String               @id @default(cuid())
  apenadoId      String
  apenado        SipeApenadoImportado @relation(fields: [apenadoId], references: [id], onDelete: Cascade)
  sipeProcessoId Int?
  numero         String?
  vara           String?
  artigos        String[]
  tempoPena      String?
  principal      Boolean              @default(false)
  createdAt      DateTime             @default(now())

  @@index([apenadoId])
  @@map("sipe_processos")
}

model SipeAdvogado {
  id           String   @id @default(cuid())
  sipeId       Int      @unique
  nome         String
  oab          String?
  cpf          String?
  endereco     String?
  telefone     String?
  dataCadastro String?
  photoPath    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vinculos SipeVinculoAdvogado[]

  @@index([nome])
  @@index([oab])
  @@map("sipe_advogados")
}

model SipeVisitante {
  id         String   @id @default(cuid())
  nome       String
  cpf        String?
  parentesco String?
  photoPath  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vinculos SipeVinculoVisitante[]

  @@index([nome])
  @@index([cpf])
  @@map("sipe_visitantes")
}

model SipeVinculoAdvogado {
  id         String               @id @default(cuid())
  apenadoId  String
  apenado    SipeApenadoImportado @relation(fields: [apenadoId], references: [id], onDelete: Cascade)
  advogadoId String
  advogado   SipeAdvogado         @relation(fields: [advogadoId], references: [id], onDelete: Cascade)
  ativo      Boolean              @default(true)
  createdAt  DateTime             @default(now())

  @@unique([apenadoId, advogadoId])
  @@index([apenadoId])
  @@index([advogadoId])
  @@map("sipe_vinculos_advogados")
}

model SipeVinculoVisitante {
  id          String               @id @default(cuid())
  apenadoId   String
  apenado     SipeApenadoImportado @relation(fields: [apenadoId], references: [id], onDelete: Cascade)
  visitanteId String
  visitante   SipeVisitante        @relation(fields: [visitanteId], references: [id], onDelete: Cascade)
  ativo       Boolean              @default(true)
  createdAt   DateTime             @default(now())

  @@unique([apenadoId, visitanteId])
  @@index([apenadoId])
  @@index([visitanteId])
  @@map("sipe_vinculos_visitantes")
}

model SipeHistorico {
  id        String               @id @default(cuid())
  apenadoId String
  apenado   SipeApenadoImportado @relation(fields: [apenadoId], references: [id], onDelete: Cascade)
  tipo      String               // "MOVIMENTACAO", "DISCIPLINA", "TRANSFERENCIA", etc
  descricao String               @db.Text
  datahora  DateTime?
  cela      String?
  unidade   String?
  createdAt DateTime             @default(now())

  @@index([apenadoId])
  @@index([tipo])
  @@map("sipe_historicos")
}

model SipeDocumento {
  id           String               @id @default(cuid())
  apenadoId    String
  apenado      SipeApenadoImportado @relation(fields: [apenadoId], references: [id], onDelete: Cascade)
  nome         String
  tipo         String               // "FOTO", "CERTIFICADO", "RESULTADO_EXAME", etc
  dataAnexo    DateTime?
  urlDownload  String?
  descricao    String?              @db.Text
  createdAt    DateTime             @default(now())

  @@index([apenadoId])
  @@index([tipo])
  @@map("sipe_documentos")
}

model SipeFotoComplementar {
  id                  String               @id @default(cuid())
  apenadoImportadoId  String
  apenadoImportado    SipeApenadoImportado @relation(fields: [apenadoImportadoId], references: [id], onDelete: Cascade)
  apenadoLocalId      String?
  apenadoLocal        Apenado?             @relation(fields: [apenadoLocalId], references: [id], onDelete: SetNull)
  photoPath           String               @unique
  descricao           String?
  createdAt           DateTime             @default(now())

  @@index([apenadoImportadoId])
  @@index([apenadoLocalId])
  @@map("sipe_fotos_complementares")
}

model SipeSyncJob {
  id                  String    @id @default(cuid())
  // PENDING | RUNNING | COMPLETED | FAILED | INTERRUPTED
  status              String    @default("PENDING")
  tipo                String
  unidade             String?
  unidadeNome         String?
  total               Int?
  processado          Int       @default(0)
  erros               Int       @default(0)
  log                 String?   @db.Text
  // Checkpoint: lista serializada de IDs coletados (JSON array)
  idsColetados        String?   @db.Text
  // Cursor: último SIPE ID processado com sucesso (para retomar)
  ultimoIdProcessado  Int?
  // Fase atual para display no frontend
  fase                String?
  // Timestamps
  iniciadoEm          DateTime?
  finalizadoEm        DateTime?
  ultimaAtividade     DateTime?
  criadoPor           String?
  createdAt           DateTime  @default(now())

  @@index([status])
  @@map("sipe_sync_jobs")
}

// ============================================================
// AIP (Análise de Inteligência Penitenciária)
// Sistema dual de dados: SIPE (sincronizável) + Inteligência (permanente)
// ============================================================

model AIPApenado {
  id String @id @default(cuid())

  // ============ VÍNCULO COM SIPE ============
  // Permite atualizar dados SIPE de novo scraping
  // Nullable com SetNull: deletar o registro SIPE não apaga o AIP — apenas desvincula
  sipeApenadoId Int?  @unique
  sipeApenado   SipeApenadoImportado? @relation("AIPApenadoToSipeApenado", fields: [sipeApenadoId], references: [sipeId], onDelete: SetNull)

  // ============ DADOS DO SIPE (atualizáveis) ============
  // Copiados inicialmente de SipeApenadoImportado
  // Atualizados automaticamente quando novo scraping acontece

  // Dados Pessoais
  nome              String
  nomeOutro         String?
  cpf               String?
  rg                String?
  rgOrgao           String?
  dataNascimento    String? // YYYY-MM-DD
  sexo              String? // M/F
  etnia             String?
  naturalidade      String?
  nacionalidade     String?
  pais              String?
  orientacaoSexual  String?
  tipoSanguineo     String?
  grauInstrucao     String?
  religiao          String?
  estadoCivil       String?
  nomeConjuge       String?
  qtdFilhos         Int?
  nomeMae           String?
  nomePai           String?
  telefone          String?
  rji               String?

  // Dados Prisionais
  unidade           String?
  cela              String?
  regime            String?
  motivoUltimaMovimentacao String?
  situacao          String?
  dataEntrada       String?
  dataPrisao        String?
  tempoPena         String?
  faccao            String? // nome da facção conforme SIPE
  monitorado        Boolean?
  intramuro         Boolean?
  presoOriundo      String?
  oficioEntrada     String?
  celeAtual         String?
  ultimaMovimentacao DateTime?

  // Endereço Residencial
  logradouro        String?
  numero            String?
  complemento       String?
  bairro            String?
  cidade            String?
  uf                String?
  cep               String?

  // Fotos (caminho local do arquivo salvo)
  photoPath         String? // foto de identificação do apenado

  // Identificadores SIPE
  sipeId            Int     @unique

  // ============ DADOS DE INTELIGÊNCIA (imutáveis pelo Limpar Tudo) ============
  // Adicionados manualmente pelo analista, nunca sobrescritos

  // Override de facção (inteligência corrige SIPE)
  facaoRealNome        String?
  facaoNivel           String? // "confirmado", "suspeita", "negado"
  facaoDataVerificacao DateTime?
  facaoRelevancia      String? // "Membro", "Membro de Relevancia", "Liderança", "Já exerceu Liderança"
  vulgo                String?

  // Campos de inteligência gerais
  notasInteligencia String? @db.Text
  observacoes       String? @db.Text

  // Metadata de inteligência
  cadastradoEm  DateTime  @default(now())
  cadastradoPor String
  atualizadoEm  DateTime  @updatedAt
  atualizadoPor String?
  ultimaSincAt  DateTime? // quando foi sincronizado pela última vez

  // Status
  ativo Boolean @default(true)

  // Relacionamentos
  vinculos AIPVinculo[]
  fotoVisitantes AIPFotoVisitante[]
  anexos AIPApenadoAnexo[]

  @@index([sipeId])
  @@index([unidade])
  @@index([facaoRealNome])
  @@index([cadastradoEm])
  @@map("aip_apenados")
}

model AIPApenadoAnexo {
  id              String    @id @default(cuid())
  apenadoId       String
  apenado         AIPApenado @relation(fields: [apenadoId], references: [id], onDelete: Cascade)

  // Informações do arquivo
  nomeOriginal    String    // Nome original do arquivo
  nomeS3          String    // Nome armazenado em S3 (com hash)
  tipoMime        String    // application/pdf, image/jpeg, etc
  tamanhoOriginal Int       // Tamanho antes da compactação
  tamanhoS3       Int       // Tamanho após compactação

  // Localização
  urlS3           String    // https://bucket.s3.amazonaws.com/...
  chaveS3         String    // aip-anexos/apenado-id/hash-timestamp.pdf

  // Metadados
  usuarioUploadId String
  usuarioUpload   User      @relation(fields: [usuarioUploadId], references: [id])
  dataUpload      DateTime  @default(now())
  descricao       String?   @db.Text

  @@index([apenadoId])
  @@index([dataUpload])
  @@map("aip_apenado_anexos")
}

model AIPVinculo {
  id String @id @default(cuid())

  apenadoId String
  apenado   AIPApenado @relation(fields: [apenadoId], references: [id], onDelete: Cascade)

  // Para qual outro apenado em AIP?
  vinculadoComId String?

  tipo            String
  forca           String? // "confirmado", "suspeita", "negado"
  notaVinculo     String? @db.Text
  documentadoEm   DateTime @default(now())
  documentadoPor  String

  @@index([apenadoId])
  @@index([tipo])
  @@map("aip_vinculos")
}

model AIPFotoVisitante {
  id String @id @default(cuid())

  apenadoId String
  apenado   AIPApenado @relation(fields: [apenadoId], references: [id], onDelete: Cascade)

  // Dados do visitante (copiado de SipeVinculoVisitante)
  visitanteId  String?
  nomeVisitante String?
  cpfVisitante  String?
  parentescoVisitante String?
  ativoVisitante Boolean?

  // Foto do visitante
  photoPath     String? // caminho do arquivo de foto
  descricao     String? // descrição/notas sobre a foto

  // Metadata
  sincronizadoEm DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  @@unique([apenadoId, visitanteId])
  @@index([apenadoId])
  @@index([visitanteId])
  @@map("aip_fotos_visitantes")
}

// ── Sistema de Avisos de Manutenção ──────────────────────────────
model SystemMaintenance {
  id String @id @default(cuid())

  // Conteúdo do aviso
  title       String
  message     String      @db.Text
  status      MaintenanceStatus @default(DRAFT)
  severity    MaintenanceSeverity @default(WARNING)

  // Grace time / Countdown (opcional)
  // Se null, aviso fica indefinido
  // Se preenchido, mostra countdown até esta data
  graceTimeUntil DateTime?

  // Auditoria
  createdBy   String
  createdByUser User @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("system_maintenance")
}

// ── Mural de Eventos ────────────────────────────────────────────
// Sistema de calendário de ocorrências com anexos (fotos/documentos)
// Suporta compartilhamento entre usuários e gerenciamento de permissões

model OccurrenceEvent {
  id        String   @id @default(cuid())

  // Informações do evento
  titulo    String
  descricao String?  @db.Text
  categoria String?  // ex: "Movimento", "Conflito", "Inteligência", etc

  // Data/Hora do evento
  dataEvento    DateTime
  dataOcorrencia DateTime @default(now()) // quando foi registrado

  // Relacionamentos
  anexos        EventAttachment[]
  solicitacoes  DeleteApprovalRequest[]

  // Auditoria
  criadoPor     String
  criadoByUser  User @relation("EventsCreatedBy", fields: [criadoPor], references: [id], onDelete: SetNull)
  criadoEm      DateTime @default(now())

  atualizadoPor String?
  atualizadoByUser User? @relation("EventsUpdatedBy", fields: [atualizadoPor], references: [id], onDelete: SetNull)
  atualizadoEm  DateTime @updatedAt

  // Soft delete
  deletadoEm    DateTime?
  deletadoPor   String?
  deletadoByUser User? @relation("EventsDeletedBy", fields: [deletadoPor], references: [id], onDelete: SetNull)

  @@index([dataEvento])
  @@index([categoria])
  @@index([criadoEm])
  @@index([deletadoEm])
  @@map("occurrence_events")
}

model EventAttachment {
  id        String   @id @default(cuid())

  // Relacionamento com evento
  eventId   String
  event     OccurrenceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Informações do arquivo
  nomeOriginal String    // nome que o usuário viu
  nomeS3       String    // hash/path em S3
  tipo         String    // 'foto', 'pdf', 'documento', 'outro'
  tipoMime     String    // application/pdf, image/jpeg, etc
  tamanho      Int       // em bytes
  urlS3        String    // URL completa ou path em S3

  // Metadados
  uploadedBy    String
  uploadedByUser User @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)
  uploadedAt    DateTime @default(now())

  // Soft delete (usuário comum pode "deletar", precisa aprovação)
  deletadoEm    DateTime?
  deletadoPor   String?

  // Relação inversa com pedidos de deleção
  deletionRequests DeleteApprovalRequest[]

  @@index([eventId])
  @@index([uploadedAt])
  @@map("event_attachments")
}

model DeleteApprovalRequest {
  id        String   @id @default(cuid())

  // O que está sendo deletado
  eventId   String?
  event     OccurrenceEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  attachmentId String?
  attachment   EventAttachment? @relation(fields: [attachmentId], references: [id], onDelete: SetNull)

  // Quem pediu a deleção
  solicitadoPor String
  solicitadoByUser User @relation("DeletionRequestedBy", fields: [solicitadoPor], references: [id], onDelete: SetNull)
  motivo       String? @db.Text
  solicitadoEm DateTime @default(now())

  // Status da aprovação
  status       String  @default("PENDENTE") // PENDENTE, APROVADO, REJEITADO
  resposta     String? @db.Text

  // Quem respondeu
  respondidoPor String?
  respondidoByUser User? @relation("DeletionRespondedBy", fields: [respondidoPor], references: [id], onDelete: SetNull)
  respondidoEm DateTime?

  @@index([status])
  @@index([eventId])
  @@index([attachmentId])
  @@index([solicitadoEm])
  @@map("event_deletion_requests")
}

model AparelhoApreendido {
