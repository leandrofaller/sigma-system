# SIPE Integration — Configurações do Backend Python

# URL Base do SIPE (padrão)
SIPE_BASE_URL=https://sipe.sejus.ro.gov.br

# Cookies de sessão obtidos após o login no SIPE
# NOTA: Esses cookies são confidenciais, expiram periodicamente e nunca devem ser salvos no código-fonte.
SIPE_COOKIE_LARAVEL_SESSION=seu_cookie_laravel_session_aqui
SIPE_COOKIE_XSRF_TOKEN=seu_cookie_xsrf_token_aqui
