# ── AWS S3 Configuration (para Mural de Eventos) ──────────────────
AWS_REGION="us-east-2"
AWS_ACCESS_KEY_ID="suas-credenciais-aqui"
AWS_SECRET_ACCESS_KEY="suas-credenciais-aqui"
S3_BUCKET_NAME="sigma-aip-s3-user"

# ── Outras configurações (manter existentes) ────────────────────
DATABASE_URL="sua-url-do-banco"
NEXTAUTH_SECRET="sua-secret"
NEXTAUTH_URL="http://localhost:3000"

# SIPE Credentials
SIPE_CPF="seu-cpf"
SIPE_SENHA="sua-senha"
SIPE_PERFIL="2"
SIPE_UNIDADE="3"

# Google Drive (opcional)
GOOGLE_DRIVE_CLIENT_ID=""
GOOGLE_DRIVE_CLIENT_SECRET=""
GOOGLE_DRIVE_REFRESH_TOKEN=""

# AI Provider
GROQ_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# Firecrawl (opcional)
FIRECRAWL_MODE="self-hosted"
FIRECRAWL_BASE_URL="http://localhost:3002"
FIRECRAWL_API_KEY=""

# Email (opcional)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# IA Facial / ArcFace (opcional localmente se não testar reconhecimento facial)
# ARCFACE_PYTHON="python"
# FACE_ANALYSIS_TIMEOUT=90000
